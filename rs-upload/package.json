{
    "name": "@parelabo/rs-upload",
    "version": "0.4.0",
    "description": "依存ゼロのファイルアップロードUI＋転送エンジン",
    "type": "module",
    "main": "./dist/rs-upload.esm.min.js",
    "module": "./dist/rs-upload.esm.min.js",
    "unpkg": "./dist/rs-upload.min.js",
    "jsdelivr": "./dist/rs-upload.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/rs-upload.esm.min.js",
            "default": "./dist/rs-upload.esm.min.js"
        },
        "./dist/*": "./dist/*",
        "./rs-upload.css": "./dist/rs-upload.css",
        "./vue": {
            "types": "./dist/types/vue.d.ts",
            "import": "./dist/rs-upload.vue.esm.min.js"
        },
        "./react": {
            "types": "./dist/types/react.d.ts",
            "import": "./dist/rs-upload.react.esm.min.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "upload",
        "file",
        "drag-and-drop",
        "dropzone",
        "uploader",
        "progress",
        "widget"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "homepage": "https://github.com/sano1023/rs-package/tree/main/rs-upload#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sano1023/rs-package.git",
        "directory": "rs-upload"
    },
    "bugs": {
        "url": "https://parelabo.com",
        "email": "contact@parelabo.com"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-upload.css",
    "peerDependencies": {
        "vue": "^3.0.0",
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        },
        "react": {
            "optional": true
        }
    }
}
