{
    "name": "@parelabo/rs-sheet",
    "version": "0.5.0",
    "description": "本格数式エンジン内蔵・依存ゼロのセル指向スプレッドシートライブラリ",
    "type": "module",
    "main": "./dist/rs-sheet.esm.min.js",
    "module": "./dist/rs-sheet.esm.min.js",
    "unpkg": "./dist/rs-sheet.min.js",
    "jsdelivr": "./dist/rs-sheet.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/rs-sheet.esm.min.js",
            "default": "./dist/rs-sheet.esm.min.js"
        },
        "./dist/*": "./dist/*",
        "./rs-sheet.css": "./dist/rs-sheet.css",
        "./vue": {
            "types": "./dist/types/vue.d.ts",
            "import": "./dist/rs-sheet.vue.esm.min.js"
        },
        "./react": {
            "types": "./dist/types/react.d.ts",
            "import": "./dist/rs-sheet.react.esm.min.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "spreadsheet",
        "excel",
        "formula",
        "grid",
        "datagrid",
        "worksheet"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "homepage": "https://github.com/sano1023/rs-package/tree/main/rs-sheet#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sano1023/rs-package.git",
        "directory": "rs-sheet"
    },
    "bugs": {
        "url": "https://parelabo.com",
        "email": "contact@parelabo.com"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-sheet.css",
    "peerDependencies": {
        "vue": "^3.0.0",
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        },
        "react": {
            "optional": true
        }
    }
}
