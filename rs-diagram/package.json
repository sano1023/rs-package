        },
        "./dist/*": "./dist/*",
        "./rs-diagram.css": "./dist/rs-diagram.css"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "diagram",
        "flowchart",
        "editor",
        "svg",
        "graph",
        "plugin"
