{
    "name": "@parelabo/rs-editor",
    "version": "0.5.0",
    "description": "プラグインアーキテクチャを持つ、依存ゼロのWYSIWYGエディタライブラリ",
    "type": "module",
    "main": "./dist/esm/index.js",
    "module": "./dist/esm/index.js",
    "unpkg": "./dist/rs-editor.min.js",
    "jsdelivr": "./dist/rs-editor.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/esm/index.js",
            "default": "./dist/esm/index.js"
        },
        "./dist/*": "./dist/*",
        "./rs-editor.css": "./dist/rs-editor.css",
        "./vue": {
            "types": "./dist/types/vue.d.ts",
            "import": "./dist/rs-editor.vue.esm.min.js"
        },
        "./react": {
            "types": "./dist/types/react.d.ts",
            "import": "./dist/rs-editor.react.esm.min.js"
        },
        "./plugins/*.js": {
            "types": "./dist/types/plugins/*.d.ts",
            "import": "./dist/esm/plugins/*.js"
        },
        "./plugins/*": {
            "types": "./dist/types/plugins/*.d.ts",
            "import": "./dist/esm/plugins/*.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "wysiwyg",
        "editor",
        "rich-text",
        "contenteditable",
        "plugin"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "homepage": "https://github.com/sano1023/rs-package/tree/main/rs-editor#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sano1023/rs-package.git",
        "directory": "rs-editor"
    },
    "bugs": {
        "url": "https://parelabo.com",
        "email": "contact@parelabo.com"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-editor.css",
    "peerDependencies": {
        "vue": "^3.0.0",
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        },
        "react": {
            "optional": true
        }
    }
}
