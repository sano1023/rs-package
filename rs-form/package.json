{
    "name": "@parelabo/rs-form",
    "version": "0.5.0",
    "description": "依存ゼロのスキーマ駆動フォームビルダー",
    "type": "module",
    "main": "./dist/esm/index.js",
    "module": "./dist/esm/index.js",
    "unpkg": "./dist/rs-form.min.js",
    "jsdelivr": "./dist/rs-form.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/esm/index.js",
            "default": "./dist/esm/index.js"
        },
        "./dist/*": "./dist/*",
        "./rs-form.css": "./dist/rs-form.css",
        "./vue": {
            "types": "./dist/types/vue.d.ts",
            "import": "./dist/rs-form.vue.esm.min.js"
        },
        "./react": {
            "types": "./dist/types/react.d.ts",
            "import": "./dist/rs-form.react.esm.min.js"
        },
        "./builder": {
            "types": "./dist/types/builder.d.ts",
            "import": "./dist/esm/builder.js"
        },
        "./conversational": {
            "types": "./dist/types/conversational.d.ts",
            "import": "./dist/esm/conversational.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "form",
        "survey",
        "questionnaire",
        "schema",
        "validation",
        "japanese",
        "plugin"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "homepage": "https://github.com/sano1023/rs-package/tree/main/rs-form#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sano1023/rs-package.git",
        "directory": "rs-form"
    },
    "bugs": {
        "url": "https://parelabo.com",
        "email": "contact@parelabo.com"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-form.css",
    "peerDependencies": {
        "vue": "^3.0.0",
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        },
        "react": {
            "optional": true
        }
    }
}
