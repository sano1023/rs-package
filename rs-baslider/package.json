{
    "name": "@parelabo/rs-baslider",
    "version": "0.1.0",
    "description": "Before/After比較スライダー（依存ゼロ・横/縦・タッチ対応・ラベル・複数設置）",
    "type": "module",
    "main": "./dist/rs-baslider.esm.min.js",
    "module": "./dist/rs-baslider.esm.min.js",
    "unpkg": "./dist/rs-baslider.min.js",
    "jsdelivr": "./dist/rs-baslider.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/rs-baslider.esm.min.js",
            "default": "./dist/rs-baslider.esm.min.js"
        },
        "./dist/*": "./dist/*",
        "./rs-baslider.css": "./dist/rs-baslider.css",
        "./vue": {
            "types": "./dist/types/vue.d.ts",
            "import": "./dist/rs-baslider.vue.esm.min.js"
        },
        "./react": {
            "types": "./dist/types/react.d.ts",
            "import": "./dist/rs-baslider.react.esm.min.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "before-after",
        "image-comparison",
        "slider"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "homepage": "https://github.com/sano1023/rs-package/tree/main/rs-baslider#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/sano1023/rs-package.git",
        "directory": "rs-baslider"
    },
    "bugs": {
        "url": "https://parelabo.com",
        "email": "contact@parelabo.com"
    },
    "publishConfig": {
        "access": "public"
    },
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-baslider.css",
    "peerDependencies": {
        "vue": "^3.0.0",
        "react": ">=18"
    },
    "peerDependenciesMeta": {
        "vue": {
            "optional": true
        },
        "react": {
            "optional": true
        }
    }
}
