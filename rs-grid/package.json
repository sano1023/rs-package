{
    "name": "rs-grid",
    "version": "0.4.1",
    "description": "Excel風データグリッド（依存ゼロ・仮想スクロール・Excel互換コピペ・フィルハンドル・undo/redo）",
    "type": "module",
    "main": "./dist/rs-grid.esm.min.js",
    "module": "./dist/rs-grid.esm.min.js",
    "unpkg": "./dist/rs-grid.min.js",
    "jsdelivr": "./dist/rs-grid.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/rs-grid.esm.min.js",
