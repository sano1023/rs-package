        },
        "./dist/*": "./dist/*",
        "./rs-grid.css": "./dist/rs-grid.css"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "datagrid",
        "spreadsheet",
        "excel",
        "handsontable",
        "table"
