{
    "name": "rs-pivot",
    "version": "0.1.0",
    "description": "有料ピボットテーブルライブラリの機能網羅を目指す、依存ゼロのピボットテーブルライブラリ",
    "type": "module",
    "main": "./dist/rs-pivot.esm.min.js",
    "module": "./dist/rs-pivot.esm.min.js",
    "unpkg": "./dist/rs-pivot.min.js",
    "jsdelivr": "./dist/rs-pivot.min.js",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/rs-pivot.esm.min.js",
            "default": "./dist/rs-pivot.esm.min.js"
        },
        "./dist/*": "./dist/*",
        "./rs-pivot.css": "./dist/rs-pivot.css"
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "pivot",
        "pivot-table",
        "aggregation",
        "olap",
        "bi",
        "data-analysis"
    ],
    "author": "ryusuke.sano <ryusuke.sano@parelabo.com>",
    "license": "SEE LICENSE IN LICENSE.txt",
    "types": "./dist/types/index.d.ts",
    "style": "./dist/rs-pivot.css"
}
